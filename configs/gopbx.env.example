# gopbx 使用 koanf 从环境变量加载配置。
# 约定：双下划线 __ 表示层级分隔，如 server.address => GOPBX_SERVER__ADDRESS。

GOPBX_SERVER__ADDRESS=:8080
GOPBX_SERVER__SHUTDOWN_TIMEOUT=10s

GOPBX_LLM_PROXY__ENDPOINT=https://api.openai.com/v1
GOPBX_LLM_PROXY__API_KEY=

GOPBX_ICE_PROVIDER__ENDPOINT=
GOPBX_ICE_PROVIDER__API_KEY=
GOPBX_ICE_PROVIDER__TIMEOUT=3s

GOPBX_CALLRECORD__TYPE=local
GOPBX_CALLRECORD__ENDPOINT=
GOPBX_CALLRECORD__BUCKET=
GOPBX_CALLRECORD__PREFIX=gopbx
GOPBX_CALLRECORD__API_KEY=
GOPBX_CALLRECORD__TIMEOUT=5s

GOPBX_RECORDER_PATH=./tmp/recordings

GOPBX_ICE_SERVERS='[{"urls":["stun:stun.l.google.com:19302"]}]'
